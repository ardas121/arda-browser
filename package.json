{
  "name": "arda-browser",
  "version": "1.0.11",
  "description": "Arda Browser - Brave benzeri, reklam/izleyici engelleyici tarayici",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis",
    "dist:dir": "electron-builder --win dir"
  },
  "author": "Arda",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.arda.browser",
    "productName": "Arda Browser",
    "artifactName": "Arda-Browser-Setup.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "icon.ico",
      "README.txt",
      "LICENSE",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "README.txt",
        "to": "README.txt"
      },
      {
        "from": "LICENSE",
        "to": "LICENSE"
      }
    ],
    "win": {
      "icon": "icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/uninstallerSidebar.bmp",
      "oneClick": false,
      "displayLanguageSelector": true,
      "installerLanguages": [
        "tr_TR",
        "en_US",
        "de_DE",
        "fr_FR",
        "es_ES",
        "pt_PT",
        "ru_RU",
        "ar_SA",
        "zh_CN",
        "ja_JP",
        "ko_KR",
        "hi_IN"
      ],
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Arda Browser"
    }
  },
  "dependencies": {
    "@ghostery/adblocker": "^2.18.0"
  }
}
